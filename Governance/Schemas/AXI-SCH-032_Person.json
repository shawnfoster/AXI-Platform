{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-032",
  "title": "AXI Person",
  "description": "Governed constitutional representation of an individual participant, steward, or stakeholder within the Organization Intelligence domain of the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "lifecycle_state",
    "identity",
    "affiliation",
    "governance",
    "ownership",
    "relationships",
    "traceability",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-PLT"
    },
    "object_type": {
      "type": "string",
      "const": "Person"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "Active",
        "Review",
        "Deprecated",
        "Archive Candidate",
        "Archived",
        "Historical",
        "Eligible for Disposal"
      ]
    },
    "identity": {
      "type": "object",
      "required": [
        "canonical_name",
        "person_kind",
        "participation_summary"
      ],
      "properties": {
        "canonical_name": {
          "type": "string",
          "minLength": 1
        },
        "preferred_name": {
          "type": "string",
          "minLength": 1
        },
        "person_kind": {
          "type": "string",
          "minLength": 1
        },
        "participation_summary": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "$ref": "#/$defs/stringArray"
        },
        "external_identifiers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "system",
              "value"
            ],
            "properties": {
              "system": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "affiliation": {
      "type": "object",
      "required": [
        "primary_organization_id",
        "role_ids",
        "stakeholder_groups"
      ],
      "properties": {
        "primary_organization_id": {
          "$ref": "#/$defs/objectRef"
        },
        "role_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "stakeholder_groups": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": [
        "approval_authority",
        "governing_adr_refs",
        "governing_publication_refs"
      ],
      "properties": {
        "approval_authority": {
          "type": "string",
          "minLength": 1
        },
        "governing_adr_refs": {
          "$ref": "#/$defs/adrRefArrayMinOne"
        },
        "governing_publication_refs": {
          "$ref": "#/$defs/publicationRefArrayMinOne"
        }
      },
      "additionalProperties": false
    },
    "ownership": {
      "type": "object",
      "required": [
        "accountable_owner",
        "steward_role_ids"
      ],
      "properties": {
        "accountable_owner": {
          "type": "string",
          "minLength": 1
        },
        "steward_role_ids": {
          "$ref": "#/$defs/objectRefArrayMinOne"
        },
        "primary_organization_id": {
          "$ref": "#/$defs/objectRef"
        }
      },
      "additionalProperties": false
    },
    "relationships": {
      "type": "object",
      "required": [
        "related_organization_ids",
        "related_person_ids",
        "related_role_ids",
        "related_policy_ids",
        "related_timeline_ids",
        "related_resource_ids",
        "related_dependency_ids",
        "related_knowledge_ids",
        "related_expertise_ids"
      ],
      "properties": {
        "related_organization_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_person_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_role_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_policy_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_timeline_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_resource_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_dependency_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_knowledge_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_expertise_ids": {
          "$ref": "#/$defs/objectRefArray"
        }
      },
      "additionalProperties": false
    },
    "traceability": {
      "type": "object",
      "required": [
        "evidence_refs",
        "publication_refs",
        "related_decision_ids",
        "lifecycle_record_ids"
      ],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "publication_refs": {
          "$ref": "#/$defs/publicationRefArray"
        },
        "related_decision_ids": {
          "$ref": "#/$defs/decisionRefArray"
        },
        "lifecycle_record_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "review_case_ids": {
          "$ref": "#/$defs/objectRefArray"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "objectRef": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "objectRefArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/objectRef"
      },
      "uniqueItems": true
    },
    "objectRefArrayMinOne": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/objectRef"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "decisionRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DEC-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "publicationRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^PUB-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "publicationRefArrayMinOne": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^PUB-[0-9]{3}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "adrRefArrayMinOne": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADR-[0-9]{4}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "$ref": "#/$defs/objectRef"
        },
        "schema_id": {
          "type": "string",
          "pattern": "^AXI-SCH-[0-9]{3}$"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
