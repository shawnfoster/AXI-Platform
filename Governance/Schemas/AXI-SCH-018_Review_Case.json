{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-018",
  "title": "AXI Review Case",
  "description": "Governed review and quarantine case for imported or suspect content in the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "workflow_status",
    "risk_classifications",
    "severity",
    "review_authorities",
    "quarantine_status",
    "source_artifact_refs",
    "governed_ingest_permitted",
    "disposition",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-RVW"
    },
    "object_type": {
      "type": "string",
      "const": "ReviewCase"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "workflow_status": {
      "type": "string",
      "enum": [
        "Submitted",
        "Screening",
        "Under Review",
        "Escalated",
        "Awaiting Disposition",
        "Dispositioned",
        "Closed"
      ]
    },
    "risk_classifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "Security",
          "Privacy",
          "Legal",
          "Compliance",
          "Governance",
          "Provenance",
          "Content",
          "Quality",
          "Executive Review"
        ]
      },
      "uniqueItems": true
    },
    "severity": {
      "type": "string",
      "enum": [
        "Informational",
        "Low",
        "Moderate",
        "High",
        "Critical"
      ]
    },
    "review_authorities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "Content Steward",
          "Governance Steward",
          "Provenance Steward",
          "Security Review",
          "Privacy Review",
          "Legal Review",
          "Compliance Review",
          "Executive Review"
        ]
      },
      "uniqueItems": true
    },
    "quarantine_status": {
      "type": "string",
      "enum": [
        "Not Quarantined",
        "Quarantined",
        "Released",
        "Retained",
        "Archived"
      ]
    },
    "source_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifactRef"
      },
      "uniqueItems": true
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "classification",
          "summary",
          "severity"
        ],
        "properties": {
          "classification": {
            "type": "string",
            "enum": [
              "Security",
              "Privacy",
              "Legal",
              "Compliance",
              "Governance",
              "Provenance",
              "Content",
              "Quality",
              "Executive Review"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "Informational",
              "Low",
              "Moderate",
              "High",
              "Critical"
            ]
          },
          "required_review_authorities": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Content Steward",
                "Governance Steward",
                "Provenance Steward",
                "Security Review",
                "Privacy Review",
                "Legal Review",
                "Compliance Review",
                "Executive Review"
              ]
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "governed_ingest_permitted": {
      "type": "boolean"
    },
    "release_requirements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disposition": {
      "type": "object",
      "required": [
        "decision",
        "rationale"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "Approved",
            "Approved with Restrictions",
            "Rejected",
            "Retain in Quarantine"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "approved_by": {
          "type": "string"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "type": "string",
          "pattern": "^OBJ-[0-9]{6}$"
        },
        "schema_id": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
