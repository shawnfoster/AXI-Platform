{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-007",
  "title": "AXI Platform Object",
  "description": "Canonical object definition for every governed artifact in the AXI Platform.",
  "type": "object",

  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "created_at"
  ],

  "properties": {

    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$",
      "description": "Immutable platform object identifier."
    },

    "namespace": {
      "type": "string",
      "enum": [
        "AXI-PLT",
        "AXI-ENG",
        "AXI-SVC",
        "AXI-APP",
        "AXI-REG",
        "AXI-SCH",
        "AXI-STD",
        "AXI-DEC",
        "AXI-ADR",
        "AXI-RVW",
        "AXI-TST",
        "AXI-API",
        "AXI-GUI",
        "AXI-CLI",
        "AXI-CAP"
      ]
    },

    "object_type": {
      "type": "string",
      "enum": [
        "Platform",
        "Engine",
        "Service",
        "Application",
        "Register",
        "Schema",
        "Standard",
        "Decision",
        "ADR",
        "Capability",
        "API",
        "CLI",
        "GUI",
        "Test"
      ]
    },

    "name": {
      "type": "string",
      "minLength": 1
    },

    "description": {
      "type": "string"
    },

    "version": {
      "type": "string"
    },

    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },

    "owner": {
      "type": "string"
    },

    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CAP-[0-9]{3}$"
      },
      "uniqueItems": true
    },

    "contracts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },

    "schemas": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },

    "adr_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADR-[0-9]{4}$"
      },
      "uniqueItems": true
    },

    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^OBJ-[0-9]{6}$"
      },
      "uniqueItems": true
    },

    "provenance": {
      "type": "object",
      "properties": {
        "created_by": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "source_reference": {
          "type": "string"
        }
      }
    },

    "created_at": {
      "type": "string",
      "format": "date-time"
    },

    "updated_at": {
      "type": "string",
      "format": "date-time"
    },

    "metadata": {
      "type": "object",
      "additionalProperties": true
    }

  },

  "additionalProperties": false
}