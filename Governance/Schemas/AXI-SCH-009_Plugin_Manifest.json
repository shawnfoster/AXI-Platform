{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-009",
  "title": "AXI Plugin Manifest",
  "description": "Manifest definition for governed runtime plugins in the AXI Platform.",
  "type": "object",
  "required": [
    "plugin_id",
    "name",
    "version",
    "author",
    "description",
    "capabilities",
    "dependencies",
    "lifecycle_state"
  ],
  "properties": {
    "plugin_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CAP-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "lifecycle_state": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
