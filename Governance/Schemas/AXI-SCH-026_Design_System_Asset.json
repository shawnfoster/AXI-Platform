{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-026",
  "title": "AXI Design System Asset",
  "description": "Governed design-system asset definition for brand kits, themes, and template-bearing visual system objects in AXI.",
  "type": "object",
  "required": [
    "asset_id",
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "scope",
    "typography",
    "color_system",
    "iconography",
    "illustration_style",
    "diagram_style",
    "layout_grid",
    "export_profiles",
    "accessibility",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "pattern": "^(BRK|THM|TPL)-[0-9]{3}$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-GUI"
    },
    "object_type": {
      "type": "string",
      "enum": [
        "BrandKit",
        "Theme",
        "Template"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": [
        "Platform",
        "Organization",
        "Experience",
        "Export"
      ]
    },
    "inheritance": {
      "type": "object",
      "properties": {
        "base_asset_id": {
          "type": "string",
          "pattern": "^(BRK|THM|TPL)-[0-9]{3}$"
        },
        "override_mode": {
          "type": "string",
          "enum": [
            "Locked",
            "Extend",
            "Substitute"
          ]
        }
      },
      "additionalProperties": false
    },
    "typography": {
      "type": "object",
      "required": [
        "primary_font_family",
        "secondary_font_family",
        "typography_scale_ref"
      ],
      "properties": {
        "primary_font_family": {
          "type": "string",
          "minLength": 1
        },
        "secondary_font_family": {
          "type": "string",
          "minLength": 1
        },
        "typography_scale_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "color_system": {
      "type": "object",
      "required": [
        "palette_mode",
        "token_count",
        "contrast_standard"
      ],
      "properties": {
        "palette_mode": {
          "type": "string",
          "enum": [
            "Core",
            "Organization",
            "Campaign",
            "Accessibility Override"
          ]
        },
        "token_count": {
          "type": "integer",
          "minimum": 1
        },
        "contrast_standard": {
          "type": "string",
          "enum": [
            "WCAG AA",
            "WCAG AAA"
          ]
        }
      },
      "additionalProperties": false
    },
    "iconography": {
      "type": "object",
      "required": [
        "icon_family",
        "stroke_style",
        "sizing_scale_ref"
      ],
      "properties": {
        "icon_family": {
          "type": "string",
          "minLength": 1
        },
        "stroke_style": {
          "type": "string",
          "minLength": 1
        },
        "sizing_scale_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "illustration_style": {
      "type": "object",
      "required": [
        "style_name"
      ],
      "properties": {
        "style_name": {
          "type": "string",
          "minLength": 1
        },
        "allowed_motifs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "diagram_style": {
      "type": "object",
      "required": [
        "notation_defaults"
      ],
      "properties": {
        "notation_defaults": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "emphasis_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "component_families": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "layout_grid": {
      "type": "object",
      "required": [
        "column_system",
        "spacing_scale_ref"
      ],
      "properties": {
        "column_system": {
          "type": "string",
          "enum": [
            "4-column",
            "8-column",
            "12-column",
            "Responsive Hybrid"
          ]
        },
        "spacing_scale_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "export_profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Web",
          "Mobile",
          "PDF",
          "Print",
          "Presentation",
          "White Label"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "accessibility": {
      "type": "object",
      "required": [
        "motion_policy",
        "contrast_enforcement",
        "text_scaling_support"
      ],
      "properties": {
        "motion_policy": {
          "type": "string",
          "minLength": 1
        },
        "contrast_enforcement": {
          "type": "boolean",
          "const": true
        },
        "text_scaling_support": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "related_artifact_spec_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^AS-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
