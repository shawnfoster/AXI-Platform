{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-015",
  "title": "AXI Information Lifecycle Record",
  "description": "Governed lifecycle and transition record for repository information in the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "subject_artifact_refs",
    "lifecycle_state",
    "manual_disposal_only",
    "transition_history",
    "traceability",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-RVW"
    },
    "object_type": {
      "type": "string",
      "const": "LifecycleRecord"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "subject_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifactRef"
      },
      "uniqueItems": true
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "Active",
        "Review",
        "Deprecated",
        "Archive Candidate",
        "Archived",
        "Historical",
        "Eligible for Disposal"
      ]
    },
    "manual_disposal_only": {
      "type": "boolean"
    },
    "holds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "transition_history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "from_state",
          "to_state",
          "reason",
          "authorized_by",
          "authorized_at",
          "evidence_refs"
        ],
        "properties": {
          "from_state": {
            "type": "string",
            "enum": [
              "Active",
              "Review",
              "Deprecated",
              "Archive Candidate",
              "Archived",
              "Historical",
              "Eligible for Disposal"
            ]
          },
          "to_state": {
            "type": "string",
            "enum": [
              "Active",
              "Review",
              "Deprecated",
              "Archive Candidate",
              "Archived",
              "Historical",
              "Eligible for Disposal"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "authorized_by": {
            "type": "string",
            "minLength": 1
          },
          "authorized_at": {
            "type": "string",
            "format": "date-time"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/artifactRef"
            },
            "uniqueItems": true
          },
          "related_decision_ids": {
            "$ref": "#/$defs/objectRefArray"
          },
          "related_review_case_ids": {
            "$ref": "#/$defs/objectRefArray"
          },
          "archive_package_ids": {
            "$ref": "#/$defs/objectRefArray"
          },
          "dependency_impact_summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "traceability": {
      "type": "object",
      "required": [
        "provenance_complete",
        "dependency_refs",
        "replacement_refs",
        "restoration_required"
      ],
      "properties": {
        "provenance_complete": {
          "type": "boolean"
        },
        "dependency_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "replacement_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "restoration_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "Eligible for Disposal"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "manual_disposal_only": {
            "const": true
          }
        }
      }
    }
  ],
  "$defs": {
    "objectRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^OBJ-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "type": "string",
          "pattern": "^OBJ-[0-9]{6}$"
        },
        "schema_id": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
