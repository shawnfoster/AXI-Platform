{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-016",
  "title": "AXI Repository Health Assessment",
  "description": "Governed repository health assessment for the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "scope",
    "assessment_window",
    "measured_at",
    "metrics",
    "overall_health_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-RVW"
    },
    "object_type": {
      "type": "string",
      "const": "HealthAssessment"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": [
        "repository_root",
        "included_paths"
      ],
      "properties": {
        "repository_root": {
          "type": "string",
          "minLength": 1
        },
        "included_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "excluded_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "assessment_window": {
      "type": "object",
      "required": [
        "start_at",
        "end_at"
      ],
      "properties": {
        "start_at": {
          "type": "string",
          "format": "date-time"
        },
        "end_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "measured_at": {
      "type": "string",
      "format": "date-time"
    },
    "metrics": {
      "type": "object",
      "required": [
        "knowledge_quality",
        "knowledge_entropy",
        "duplicate_risk",
        "provenance_coverage",
        "reference_integrity",
        "governance_compliance",
        "placeholder_artifacts",
        "canonical_coverage",
        "documentation_waste",
        "import_readiness"
      ],
      "properties": {
        "knowledge_quality": {
          "$ref": "#/$defs/metric"
        },
        "knowledge_entropy": {
          "$ref": "#/$defs/metric"
        },
        "duplicate_risk": {
          "$ref": "#/$defs/metric"
        },
        "provenance_coverage": {
          "$ref": "#/$defs/metric"
        },
        "reference_integrity": {
          "$ref": "#/$defs/metric"
        },
        "governance_compliance": {
          "$ref": "#/$defs/metric"
        },
        "placeholder_artifacts": {
          "$ref": "#/$defs/metric"
        },
        "canonical_coverage": {
          "$ref": "#/$defs/metric"
        },
        "documentation_waste": {
          "$ref": "#/$defs/metric"
        },
        "import_readiness": {
          "$ref": "#/$defs/metric"
        }
      },
      "additionalProperties": false
    },
    "overall_health_status": {
      "type": "string",
      "enum": [
        "Healthy",
        "Watch",
        "At Risk",
        "Critical"
      ]
    },
    "priority_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": [
        "health_score",
        "status",
        "trend",
        "basis",
        "evidence_refs"
      ],
      "properties": {
        "health_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "type": "string",
          "enum": [
            "Healthy",
            "Watch",
            "At Risk",
            "Critical"
          ]
        },
        "trend": {
          "type": "string",
          "enum": [
            "Improving",
            "Stable",
            "Degrading",
            "Unknown"
          ]
        },
        "basis": {
          "type": "string",
          "minLength": 1
        },
        "observed_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "type": "string",
          "pattern": "^OBJ-[0-9]{6}$"
        },
        "schema_id": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
