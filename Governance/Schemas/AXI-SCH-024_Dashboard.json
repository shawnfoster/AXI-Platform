{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-024",
  "title": "AXI Dashboard",
  "description": "Governed dashboard definition for the AXI presentation layer.",
  "type": "object",
  "required": [
    "dashboard_id",
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "dashboard_type",
    "purpose",
    "audience",
    "governing_object_types",
    "lifecycle_stage",
    "required_widget_ids",
    "data_sources",
    "permissions",
    "validation",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "dashboard_id": {
      "type": "string",
      "pattern": "^DAS-[0-9]{3}$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-GUI"
    },
    "object_type": {
      "type": "string",
      "const": "Dashboard"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "dashboard_type": {
      "type": "string",
      "enum": [
        "Executive Dashboard",
        "Organization Dashboard",
        "Decision Dashboard",
        "Repository Dashboard",
        "Governance Dashboard",
        "Knowledge Dashboard",
        "Operational Dashboard",
        "Risk Dashboard",
        "Readiness Dashboard",
        "Project Dashboard",
        "Portfolio Dashboard",
        "Learning Dashboard",
        "Administration Dashboard"
      ]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "governing_object_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Decision",
          "DecisionContext",
          "Organization",
          "Person",
          "Role",
          "Evidence",
          "Knowledge",
          "Expertise",
          "Capability",
          "Constraint",
          "Risk",
          "Opportunity",
          "Alternative",
          "Recommendation",
          "Execution",
          "Outcome",
          "Observation",
          "Lesson",
          "Metric",
          "Objective",
          "Policy",
          "Timeline",
          "Resource",
          "Dependency",
          "Assumption",
          "LifecycleRecord",
          "HealthAssessment",
          "ArchivePackage",
          "ReviewCase",
          "OperatingContext",
          "RegulatoryKnowledge",
          "ReadinessProfile",
          "Publication",
          "Diagram"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "lifecycle_stage": {
      "type": "string",
      "enum": [
        "Defined",
        "Templated",
        "Configured",
        "Validated",
        "Published",
        "Suspended",
        "Retired"
      ]
    },
    "required_widget_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WID-[0-9]{3}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "optional_widget_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WID-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "data_sources": {
      "type": "object",
      "required": [
        "governed_schema_ids",
        "governed_object_types",
        "refresh_policy",
        "no_business_data_ownership",
        "lineage_required"
      ],
      "properties": {
        "governed_schema_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^AXI-SCH-[0-9]{3}$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "governed_object_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "refresh_policy": {
          "type": "string",
          "enum": [
            "On Demand",
            "Event-Driven",
            "Scheduled Hourly",
            "Scheduled Daily",
            "Scheduled Weekly"
          ]
        },
        "access_scope": {
          "type": "string"
        },
        "no_business_data_ownership": {
          "type": "boolean",
          "const": true
        },
        "lineage_required": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": [
        "viewer_scopes",
        "editor_scopes",
        "sharer_scopes",
        "administrator_scopes",
        "inheritance_policy"
      ],
      "properties": {
        "viewer_scopes": {
          "$ref": "#/$defs/stringArray"
        },
        "editor_scopes": {
          "$ref": "#/$defs/stringArray"
        },
        "sharer_scopes": {
          "$ref": "#/$defs/stringArray"
        },
        "administrator_scopes": {
          "$ref": "#/$defs/stringArray"
        },
        "inheritance_policy": {
          "type": "string",
          "enum": [
            "Inherited",
            "Overlay",
            "Restricted"
          ]
        }
      },
      "additionalProperties": false
    },
    "version_lineage": {
      "type": "object",
      "properties": {
        "base_dashboard_id": {
          "type": "string",
          "pattern": "^DAS-[0-9]{3}$"
        },
        "parent_dashboard_id": {
          "type": "string",
          "pattern": "^DAS-[0-9]{3}$"
        },
        "customization_mode": {
          "type": "string",
          "enum": [
            "None",
            "Layout Overlay",
            "Branding Overlay",
            "Widget Configuration Overlay",
            "Template Derivation"
          ]
        }
      },
      "additionalProperties": false
    },
    "layout_constraints": {
      "type": "object",
      "properties": {
        "supported_layouts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "Hero",
              "Two-Column",
              "Three-Column",
              "Four-Quadrant",
              "Sidebar",
              "Mobile Stack"
            ]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "validation": {
      "type": "object",
      "required": [
        "accessibility_review_required",
        "data_source_validation_required",
        "traceability_check_required",
        "permission_review_required"
      ],
      "properties": {
        "accessibility_review_required": {
          "type": "boolean",
          "const": true
        },
        "data_source_validation_required": {
          "type": "boolean",
          "const": true
        },
        "traceability_check_required": {
          "type": "boolean",
          "const": true
        },
        "permission_review_required": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
