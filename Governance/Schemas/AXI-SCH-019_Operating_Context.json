{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-019",
  "title": "AXI Operating Context",
  "description": "Governed organizational operating context for decision planning in the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "organization_id",
    "fiscal_year",
    "effective_period",
    "fiscal_calendar",
    "financial_close_windows",
    "budget_cycles",
    "strategic_planning_cycles",
    "board_calendar",
    "audit_windows",
    "stub_audit_timing",
    "regulatory_reporting_calendar",
    "contract_renewal_calendar",
    "insurance_renewal_calendar",
    "payroll_calendar",
    "benefits_calendar",
    "maintenance_windows",
    "technology_freeze_windows",
    "major_operational_events",
    "pre_execution_evaluation_required",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-PLT"
    },
    "object_type": {
      "type": "string",
      "const": "OperatingContext"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "organization_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "fiscal_year": {
      "type": "string",
      "minLength": 1
    },
    "effective_period": {
      "type": "object",
      "required": [
        "start_at",
        "end_at"
      ],
      "properties": {
        "start_at": {
          "type": "string",
          "format": "date-time"
        },
        "end_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "fiscal_calendar": {
      "$ref": "#/$defs/scheduleArray"
    },
    "financial_close_windows": {
      "$ref": "#/$defs/scheduleArray"
    },
    "budget_cycles": {
      "$ref": "#/$defs/scheduleArray"
    },
    "strategic_planning_cycles": {
      "$ref": "#/$defs/scheduleArray"
    },
    "board_calendar": {
      "$ref": "#/$defs/scheduleArray"
    },
    "audit_windows": {
      "$ref": "#/$defs/scheduleArray"
    },
    "stub_audit_timing": {
      "$ref": "#/$defs/scheduleArray"
    },
    "regulatory_reporting_calendar": {
      "$ref": "#/$defs/scheduleArray"
    },
    "contract_renewal_calendar": {
      "$ref": "#/$defs/scheduleArray"
    },
    "insurance_renewal_calendar": {
      "$ref": "#/$defs/scheduleArray"
    },
    "payroll_calendar": {
      "$ref": "#/$defs/scheduleArray"
    },
    "benefits_calendar": {
      "$ref": "#/$defs/scheduleArray"
    },
    "maintenance_windows": {
      "$ref": "#/$defs/scheduleArray"
    },
    "technology_freeze_windows": {
      "$ref": "#/$defs/scheduleArray"
    },
    "major_operational_events": {
      "$ref": "#/$defs/scheduleArray"
    },
    "pre_execution_evaluation_required": {
      "type": "boolean",
      "const": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "scheduleArray": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "start_at",
          "end_at"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "start_at": {
            "type": "string",
            "format": "date-time"
          },
          "end_at": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
