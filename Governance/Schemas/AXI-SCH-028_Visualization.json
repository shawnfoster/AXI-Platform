{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-028",
  "title": "AXI Visualization",
  "description": "Governed visualization definition for AXI dashboards, reports, documents, and presentation artifacts.",
  "type": "object",
  "required": [
    "visualization_id",
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "visualization_family",
    "approved_use_cases",
    "governed_data_source",
    "interpretability",
    "accessibility",
    "supported_export_formats",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "visualization_id": {
      "type": "string",
      "pattern": "^VIS-[0-9]{3}$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-GUI"
    },
    "object_type": {
      "type": "string",
      "const": "Visualization"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "visualization_family": {
      "type": "string",
      "enum": [
        "Chart Standard",
        "Table",
        "Timeline",
        "Heatmap",
        "Decision Tree",
        "Sankey Diagram",
        "Organizational Chart",
        "Dependency Graph",
        "Digital Twin Visualization",
        "Geographic Map",
        "KPI Card",
        "Scorecard",
        "Executive Summary"
      ]
    },
    "approved_use_cases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "prohibited_use_cases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "governed_data_source": {
      "type": "object",
      "required": [
        "source_schema_ids",
        "source_object_types",
        "aggregation_requirements"
      ],
      "properties": {
        "source_schema_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^AXI-SCH-[0-9]{3}$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_object_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "aggregation_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "interpretability": {
      "type": "object",
      "required": [
        "legend_required",
        "narrative_summary_required",
        "uncertainty_disclosure_required",
        "drillback_required"
      ],
      "properties": {
        "legend_required": {
          "type": "boolean"
        },
        "narrative_summary_required": {
          "type": "boolean"
        },
        "uncertainty_disclosure_required": {
          "type": "boolean"
        },
        "drillback_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "accessibility": {
      "type": "object",
      "required": [
        "keyboard_navigation",
        "screen_reader_summary",
        "color_independent_encoding",
        "text_alternative_required"
      ],
      "properties": {
        "keyboard_navigation": {
          "type": "boolean",
          "const": true
        },
        "screen_reader_summary": {
          "type": "boolean",
          "const": true
        },
        "color_independent_encoding": {
          "type": "boolean",
          "const": true
        },
        "text_alternative_required": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "supported_export_formats": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "HTML",
          "PNG",
          "SVG",
          "PDF",
          "PPTX"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "related_widget_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WID-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
