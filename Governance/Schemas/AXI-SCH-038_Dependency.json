{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-038",
  "title": "AXI Dependency",
  "description": "Governed constitutional representation of cross-object reliance, sequencing, and blockage relationships within the Organization Intelligence domain of the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "lifecycle_state",
    "dependency_definition",
    "governance",
    "ownership",
    "relationships",
    "traceability",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-PLT"
    },
    "object_type": {
      "type": "string",
      "const": "Dependency"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "Active",
        "Review",
        "Deprecated",
        "Archive Candidate",
        "Archived",
        "Historical",
        "Eligible for Disposal"
      ]
    },
    "dependency_definition": {
      "type": "object",
      "required": [
        "dependency_kind",
        "dependency_scope_summary",
        "source_object_id",
        "target_object_id",
        "blocking_condition_summary",
        "criticality_summary",
        "satisfaction_summary"
      ],
      "properties": {
        "dependency_kind": {
          "type": "string",
          "minLength": 1
        },
        "dependency_scope_summary": {
          "type": "string",
          "minLength": 1
        },
        "source_object_id": {
          "$ref": "#/$defs/objectRef"
        },
        "target_object_id": {
          "$ref": "#/$defs/objectRef"
        },
        "blocking_condition_summary": {
          "type": "string",
          "minLength": 1
        },
        "criticality_summary": {
          "type": "string",
          "minLength": 1
        },
        "satisfaction_summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": [
        "approval_authority",
        "governing_adr_refs",
        "governing_publication_refs"
      ],
      "properties": {
        "approval_authority": {
          "type": "string",
          "minLength": 1
        },
        "governing_adr_refs": {
          "$ref": "#/$defs/adrRefArrayMinOne"
        },
        "governing_publication_refs": {
          "$ref": "#/$defs/publicationRefArrayMinOne"
        }
      },
      "additionalProperties": false
    },
    "ownership": {
      "type": "object",
      "required": [
        "accountable_owner",
        "steward_role_ids"
      ],
      "properties": {
        "accountable_owner": {
          "type": "string",
          "minLength": 1
        },
        "steward_role_ids": {
          "$ref": "#/$defs/objectRefArrayMinOne"
        },
        "primary_organization_id": {
          "$ref": "#/$defs/objectRef"
        }
      },
      "additionalProperties": false
    },
    "relationships": {
      "type": "object",
      "required": [
        "related_organization_ids",
        "related_role_ids",
        "related_policy_ids",
        "related_timeline_ids",
        "related_resource_ids",
        "related_knowledge_ids"
      ],
      "properties": {
        "related_organization_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_role_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_policy_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_timeline_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_resource_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "related_knowledge_ids": {
          "$ref": "#/$defs/objectRefArray"
        }
      },
      "additionalProperties": false
    },
    "traceability": {
      "type": "object",
      "required": [
        "evidence_refs",
        "publication_refs",
        "related_decision_ids",
        "lifecycle_record_ids"
      ],
      "properties": {
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "publication_refs": {
          "$ref": "#/$defs/publicationRefArray"
        },
        "related_decision_ids": {
          "$ref": "#/$defs/decisionRefArray"
        },
        "lifecycle_record_ids": {
          "$ref": "#/$defs/objectRefArray"
        },
        "review_case_ids": {
          "$ref": "#/$defs/objectRefArray"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "objectRef": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "objectRefArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/objectRef"
      },
      "uniqueItems": true
    },
    "objectRefArrayMinOne": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/objectRef"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "decisionRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DEC-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "publicationRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^PUB-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "publicationRefArrayMinOne": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^PUB-[0-9]{3}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "adrRefArrayMinOne": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADR-[0-9]{4}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "$ref": "#/$defs/objectRef"
        },
        "schema_id": {
          "type": "string",
          "pattern": "^AXI-SCH-[0-9]{3}$"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
