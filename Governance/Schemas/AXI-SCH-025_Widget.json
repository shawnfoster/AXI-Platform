{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-025",
  "title": "AXI Widget",
  "description": "Governed widget definition for dashboards and rendered presentation surfaces in AXI.",
  "type": "object",
  "required": [
    "widget_id",
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "purpose",
    "visualization_type",
    "governed_data_source",
    "refresh_policy",
    "security",
    "supported_layouts",
    "accessibility",
    "related_schema_ids",
    "related_adr_ids",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "widget_id": {
      "type": "string",
      "pattern": "^WID-[0-9]{3}$"
    },
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-GUI"
    },
    "object_type": {
      "type": "string",
      "const": "Widget"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "visualization_type": {
      "type": "string",
      "enum": [
        "KPI Card",
        "Table",
        "Line Chart",
        "Bar Chart",
        "Timeline",
        "Heatmap",
        "Decision Tree",
        "Sankey Diagram",
        "Organizational Chart",
        "Dependency Graph",
        "Digital Twin Visualization",
        "Geographic Map",
        "Scorecard",
        "Executive Summary",
        "Calendar View"
      ]
    },
    "governed_data_source": {
      "type": "object",
      "required": [
        "source_schema_ids",
        "source_object_types",
        "aggregation_policy"
      ],
      "properties": {
        "source_schema_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^AXI-SCH-[0-9]{3}$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_object_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "aggregation_policy": {
          "type": "string",
          "enum": [
            "None",
            "Aggregate",
            "Compare",
            "Trend",
            "Flow",
            "Network"
          ]
        }
      },
      "additionalProperties": false
    },
    "refresh_policy": {
      "type": "string",
      "enum": [
        "On Demand",
        "Event-Driven",
        "Hourly",
        "Daily",
        "Weekly",
        "Manual Refresh"
      ]
    },
    "security": {
      "type": "object",
      "required": [
        "sensitivity",
        "row_level_security_required",
        "masking_required"
      ],
      "properties": {
        "sensitivity": {
          "type": "string",
          "enum": [
            "Public",
            "Internal",
            "Restricted",
            "Confidential"
          ]
        },
        "row_level_security_required": {
          "type": "boolean"
        },
        "masking_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "supported_layouts": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Hero",
          "Full Width",
          "Half Width",
          "Third Width",
          "Quarter Width",
          "Sidebar",
          "Mobile Stack"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "accessibility": {
      "type": "object",
      "required": [
        "keyboard_navigation",
        "screen_reader_summary",
        "color_independent_encoding"
      ],
      "properties": {
        "keyboard_navigation": {
          "type": "boolean",
          "const": true
        },
        "screen_reader_summary": {
          "type": "boolean",
          "const": true
        },
        "color_independent_encoding": {
          "type": "boolean",
          "const": true
        }
      },
      "additionalProperties": false
    },
    "related_schema_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^AXI-SCH-[0-9]{3}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "related_adr_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADR-[0-9]{4}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
