{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-021",
  "title": "AXI Readiness Profile",
  "description": "Governed multidimensional readiness profile for decision support in the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "scope_summary",
    "evaluated_at",
    "dimension_assessments",
    "overall_effect",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-DEC"
    },
    "object_type": {
      "type": "string",
      "const": "ReadinessProfile"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "decision_id": {
      "type": "string",
      "pattern": "^DEC-[0-9]{6}$"
    },
    "scope_summary": {
      "type": "string",
      "minLength": 1
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "related_operating_context_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^OBJ-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "related_regulatory_knowledge_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^OBJ-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "dimension_assessments": {
      "type": "object",
      "required": [
        "strategic_readiness",
        "leadership_readiness",
        "capacity_readiness",
        "technology_readiness",
        "governance_readiness",
        "regulatory_readiness",
        "financial_readiness",
        "change_readiness",
        "calendar_readiness",
        "knowledge_readiness"
      ],
      "properties": {
        "strategic_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "leadership_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "capacity_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "technology_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "governance_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "regulatory_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "financial_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "change_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "calendar_readiness": {
          "$ref": "#/$defs/dimension"
        },
        "knowledge_readiness": {
          "$ref": "#/$defs/dimension"
        }
      },
      "additionalProperties": false
    },
    "overall_effect": {
      "type": "string",
      "enum": [
        "Proceed",
        "Proceed With Mitigations",
        "Stage Before Execution",
        "Defer",
        "Escalate for Human Review"
      ]
    },
    "required_mitigations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommended_sequence_adjustments": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "required": [
        "score",
        "status",
        "impact_on_recommendation",
        "rationale",
        "evidence_refs"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "type": "string",
          "enum": [
            "Ready",
            "Conditionally Ready",
            "Not Ready",
            "Unknown"
          ]
        },
        "impact_on_recommendation": {
          "type": "string",
          "enum": [
            "Inform",
            "Constrain",
            "Block",
            "Escalate"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "type": "string",
          "pattern": "^OBJ-[0-9]{6}$"
        },
        "schema_id": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
