{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-020",
  "title": "AXI Regulatory Knowledge",
  "description": "Governed regulatory knowledge record for surfacing potentially applicable obligations and planning impacts in the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "knowledge_domain",
    "jurisdictions",
    "organizational_characteristics",
    "applicability_status",
    "planning_impacts",
    "required_review_authorities",
    "guidance_boundary",
    "source_artifact_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-PLT"
    },
    "object_type": {
      "type": "string",
      "const": "RegulatoryKnowledge"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "knowledge_domain": {
      "type": "string",
      "enum": [
        "Federal",
        "State",
        "Local",
        "Industry",
        "Professional Standards",
        "Internal Policy",
        "Contractual Requirements"
      ]
    },
    "jurisdictions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "organizational_characteristics": {
      "type": "object",
      "required": [
        "industries",
        "geographies",
        "entity_forms",
        "regulated_activities",
        "workforce_characteristics",
        "data_characteristics",
        "contract_characteristics"
      ],
      "properties": {
        "industries": {
          "$ref": "#/$defs/stringArray"
        },
        "geographies": {
          "$ref": "#/$defs/stringArray"
        },
        "entity_forms": {
          "$ref": "#/$defs/stringArray"
        },
        "regulated_activities": {
          "$ref": "#/$defs/stringArray"
        },
        "workforce_characteristics": {
          "$ref": "#/$defs/stringArray"
        },
        "data_characteristics": {
          "$ref": "#/$defs/stringArray"
        },
        "contract_characteristics": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": false
    },
    "applicability_status": {
      "type": "string",
      "enum": [
        "Potentially Applicable",
        "Requires Expert Review",
        "Out of Scope",
        "Unknown"
      ]
    },
    "planning_impacts": {
      "$ref": "#/$defs/stringArray"
    },
    "required_review_authorities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Governance Steward",
          "Security Review",
          "Privacy Review",
          "Legal Review",
          "Compliance Review",
          "Executive Review"
        ]
      },
      "uniqueItems": true
    },
    "related_policy_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^OBJ-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "guidance_boundary": {
      "type": "object",
      "required": [
        "legal_conclusion_asserted",
        "compliance_assertion_asserted"
      ],
      "properties": {
        "legal_conclusion_asserted": {
          "type": "boolean",
          "const": false
        },
        "compliance_assertion_asserted": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": false
    },
    "source_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifactRef"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "type": "string",
          "pattern": "^OBJ-[0-9]{6}$"
        },
        "schema_id": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
