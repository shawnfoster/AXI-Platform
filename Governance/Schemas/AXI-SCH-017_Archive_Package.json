{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-017",
  "title": "AXI Archive Package",
  "description": "Governed archival package definition for repository history in the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "historical_classifications",
    "archive_reason",
    "automatic_deletion_permitted",
    "repository_snapshot",
    "archive_manifest",
    "dependency_preservation",
    "provenance_preservation",
    "restoration_requirements",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-PLT"
    },
    "object_type": {
      "type": "string",
      "const": "ArchivePackage"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "historical_classifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "Governance History",
          "Decision History",
          "Evidence History",
          "Knowledge History",
          "Imported Content History",
          "Runtime History",
          "Release History",
          "Legal Hold History"
        ]
      },
      "uniqueItems": true
    },
    "archive_reason": {
      "type": "string",
      "minLength": 1
    },
    "automatic_deletion_permitted": {
      "type": "boolean",
      "const": false
    },
    "repository_snapshot": {
      "type": "object",
      "required": [
        "snapshot_label",
        "vcs_reference",
        "captured_at",
        "scope_paths",
        "checksum_manifest_present"
      ],
      "properties": {
        "snapshot_label": {
          "type": "string",
          "minLength": 1
        },
        "vcs_reference": {
          "type": "string",
          "minLength": 1
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "checksum_manifest_present": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "archive_manifest": {
      "type": "object",
      "required": [
        "manifest_version",
        "artifact_count",
        "artifact_refs"
      ],
      "properties": {
        "manifest_version": {
          "type": "string"
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "related_lifecycle_record_ids": {
          "$ref": "#/$defs/objectRefArray"
        }
      },
      "additionalProperties": false
    },
    "dependency_preservation": {
      "type": "object",
      "required": [
        "dependency_refs",
        "external_dependencies_documented",
        "restoration_blockers"
      ],
      "properties": {
        "dependency_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "external_dependencies_documented": {
          "type": "boolean"
        },
        "restoration_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "provenance_preservation": {
      "type": "object",
      "required": [
        "provenance_complete",
        "source_refs_preserved",
        "audit_trail_preserved"
      ],
      "properties": {
        "provenance_complete": {
          "type": "boolean"
        },
        "source_refs_preserved": {
          "type": "boolean"
        },
        "audit_trail_preserved": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "restoration_requirements": {
      "type": "object",
      "required": [
        "restorable",
        "required_tools",
        "required_approvals",
        "instructions_summary"
      ],
      "properties": {
        "restorable": {
          "type": "boolean"
        },
        "required_tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "required_approvals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "instructions_summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "objectRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^OBJ-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "type": "string",
          "pattern": "^OBJ-[0-9]{6}$"
        },
        "schema_id": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
