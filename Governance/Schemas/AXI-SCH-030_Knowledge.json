{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AXI-SCH-030",
  "title": "AXI Knowledge",
  "description": "Governed constitutional representation of durable knowledge and required information-governance metadata within the Organization Intelligence domain of the AXI Platform.",
  "type": "object",
  "required": [
    "object_id",
    "namespace",
    "object_type",
    "name",
    "version",
    "status",
    "owner",
    "lifecycle_state",
    "knowledge_domain",
    "authority",
    "provenance",
    "information_governance",
    "dependency_refs",
    "publication_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "object_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "namespace": {
      "type": "string",
      "const": "AXI-PLT"
    },
    "object_type": {
      "type": "string",
      "const": "Knowledge"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Proposed",
        "Approved",
        "Frozen",
        "Deprecated",
        "Superseded",
        "Archived"
      ]
    },
    "owner": {
      "type": "string"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "Active",
        "Review",
        "Deprecated",
        "Archive Candidate",
        "Archived",
        "Historical",
        "Eligible for Disposal"
      ]
    },
    "knowledge_domain": {
      "type": "string",
      "enum": [
        "AXI Methodology",
        "External Knowledge",
        "Organizational Knowledge",
        "Learned Knowledge"
      ]
    },
    "authority": {
      "type": "object",
      "required": [
        "approval_authority",
        "authority_scope_summary",
        "governing_adr_refs",
        "governing_publication_refs"
      ],
      "properties": {
        "approval_authority": {
          "type": "string",
          "minLength": 1
        },
        "authority_scope_summary": {
          "type": "string",
          "minLength": 1
        },
        "governing_adr_refs": {
          "$ref": "#/$defs/adrRefArrayMinOne"
        },
        "governing_publication_refs": {
          "$ref": "#/$defs/publicationRefArrayMinOne"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_artifact_refs",
        "evidence_refs",
        "provenance_complete"
      ],
      "properties": {
        "source_artifact_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/artifactRef"
          },
          "uniqueItems": true
        },
        "provenance_complete": {
          "type": "boolean"
        },
        "derived_from_knowledge_ids": {
          "$ref": "#/$defs/objectRefArray"
        }
      },
      "additionalProperties": false
    },
    "information_governance": {
      "$ref": "AXI-SCH-031_Information_Governance_Profile.json"
    },
    "related_organization_ids": {
      "$ref": "#/$defs/objectRefArray"
    },
    "related_decision_ids": {
      "$ref": "#/$defs/decisionRefArray"
    },
    "dependency_refs": {
      "$ref": "#/$defs/objectRefArray"
    },
    "publication_refs": {
      "$ref": "#/$defs/publicationRefArray"
    },
    "lifecycle_record_ids": {
      "$ref": "#/$defs/objectRefArray"
    },
    "review_case_ids": {
      "$ref": "#/$defs/objectRefArray"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "objectRef": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{6}$"
    },
    "objectRefArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/objectRef"
      },
      "uniqueItems": true
    },
    "decisionRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^DEC-[0-9]{6}$"
      },
      "uniqueItems": true
    },
    "publicationRefArray": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^PUB-[0-9]{3}$"
      },
      "uniqueItems": true
    },
    "publicationRefArrayMinOne": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^PUB-[0-9]{3}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "adrRefArrayMinOne": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ADR-[0-9]{4}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "artifactRef": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "object_id": {
          "$ref": "#/$defs/objectRef"
        },
        "schema_id": {
          "type": "string",
          "pattern": "^AXI-SCH-[0-9]{3}$"
        },
        "content_hash": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
